# Open-FDD reverse proxy (dev: no auth; add basic_auth for production — see docs/security.md).
# Port 80 → frontend; /ai/* and common API paths → API so Overview AI and similar work when using Caddy as entry.
# Phase 2: browser security headers (HSTS belongs only on HTTPS — see Caddyfile.https.example).

:80 {
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Referrer-Policy strict-origin-when-cross-origin
	}
	handle /ai* {
		reverse_proxy api:8000
	}
	handle /api* {
		uri strip_prefix /api
		reverse_proxy api:8000
	}
	handle /auth* {
		reverse_proxy api:8000
	}
	handle /ws* {
		reverse_proxy api:8000
	}
	# Open-FDD BACnet proxy (same paths as uvicorn). Catches /bacnet/* if the SPA was built without /api prefix.
	handle /bacnet* {
		reverse_proxy api:8000
	}
	handle /* {
		reverse_proxy frontend:5173
	}
}

# Internal only (not published to host): bridge containers (api, scraper) → Caddy → host :8080.
# This endpoint is path-transparent so Open-FDD can use OFDD_BACNET_SERVER_URL=http://caddy:8081.
:8081 {
	reverse_proxy host.docker.internal:8080
}
